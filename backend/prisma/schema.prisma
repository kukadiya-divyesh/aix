generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                @id @default(autoincrement())
  email            String             @unique
  name             String
  password         String
  role             Role               @default(LOCATION_USER)
  warehouseAccess Warehouse[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  exceptions       Exception[]
  outboundLines    OutboundLine[]
  inboundLogs      InboundLog[]
}

enum Role {
  ADMIN
  LOCATION_USER
}

model Warehouse {
  id        Int      @id @default(autoincrement())
  name      String
  city      String
  image     String?
  sheds     Shed[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shed {
  id             Int            @id @default(autoincrement())
  name           String
  locationCode   String?
  warehouseId    Int
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id])
  grids          Grid[]
  serialNumbers  SerialNumber[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Grid {
  id            Int            @id @default(autoincrement())
  code          String
  barcode       String
  x             Float          @default(0)
  y             Float          @default(0)
  z             Float          @default(0)
  shedId        Int
  shed          Shed           @relation(fields: [shedId], references: [id])
  serialNumbers SerialNumber[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Inbound {
  id                  Int            @id @default(autoincrement())
  po_no              String         @unique
  inv_no             String?
  be_no              String?
  igm_no             String?
  cth_no             String?
  awb_no             String?
  total_value        Float?
  duty               Float?
  country_of_origin  String?
  stock_no           String?
  product_description String?
  quantity           Float
  weight             Float?
  no_of_box          Int
  bond_date          DateTime?
  bond_expiry_date   DateTime?
  warehouse_location String?
  per_box_weight_kg  Float?
  pkg_details        String?
  qty_per_box        Float
  status             InboundStatus  @default(PENDING)
  has_exception      Boolean        @default(false)
  exceptions         Exception[]
  serialNumbers      SerialNumber[]
  outbounds          Outbound[]
  logs               InboundLog[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model InboundLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String?
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  inboundId Int
  inbound   Inbound  @relation(fields: [inboundId], references: [id])
  createdAt DateTime @default(now())
}

enum InboundStatus {
  PENDING
  PLACED
  PARTIAL
  EXCEPTION
}

model SerialNumber {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  inboundId   Int
  inbound     Inbound   @relation(fields: [inboundId], references: [id])
  shedId      Int?
  shed        Shed?     @relation(fields: [shedId], references: [id])
  gridId      Int?
  grid        Grid?     @relation(fields: [gridId], references: [id])
  status      SNStatus  @default(PRINTED)
  history     AuditLog[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum SNStatus {
  PRINTED
  IN_GATE
  PLACED
  PICKED
  OUT_GATE
}

model AuditLog {
  id             Int          @id @default(autoincrement())
  status         String
  location       String?
  timestamp      DateTime     @default(now())
  serialNumberId Int
  serialNumber   SerialNumber @relation(fields: [serialNumberId], references: [id])
}

model Outbound {
  id            Int            @id @default(autoincrement())
  inboundId     Int
  inbound       Inbound        @relation(fields: [inboundId], references: [id])
  customerName  String?
  demandQty     Int
  status        OutboundStatus @default(OPEN)
  lines         OutboundLine[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum OutboundStatus {
  OPEN
  PARTIAL
  CLOSED
}

model OutboundLine {
  id              Int      @id @default(autoincrement())
  date            DateTime @default(now())
  flightNo        String?
  sbNo            String?
  quantityIssued  Int
  balance         Int
  postedByUserId  Int
  postedBy        User     @relation(fields: [postedByUserId], references: [id])
  status          String   @default("pending")
  scannedRfids    String[]
  outboundId      Int
  outbound        Outbound @relation(fields: [outboundId], references: [id])
  createdAt       DateTime @default(now())
}

model Exception {
  id         Int      @id @default(autoincrement())
  note       String
  image      String?
  inboundId  Int
  inbound    Inbound  @relation(fields: [inboundId], references: [id])
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}
